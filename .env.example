# Admin dashboard password (required for /admin access)
ADMIN_PASSWORD=your-secure-password

# JWT secret for admin session (change in production)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_IDS=-1001234567890,123456789
# Dispatcher mode (optional): dispatcherId:groupId:groupName – fallback if none in admin settings
# e.g. -123456789:-1001234567890:Bronx Dispatch
TELEGRAM_DISPATCHERS=
# Source shown in Telegram notifications (e.g. tristatetags)
BOLDY_SOURCE=tristatetags

# OneTimeSecret (for secure phone link in dispatcher mode – https://onetimesecret.com)
ONETIMESECRET_USERNAME=
ONETIMESECRET_API_KEY=
ONETIMESECRET_REGION=us

# Google Places (address autocomplete in forms - set in Vercel as VITE_GOOGLE_PLACES_API_KEY)
VITE_GOOGLE_PLACES_API_KEY=

# Fallback: if nobody accepts within 60s, auto-assign (put in Render)
FALLBACK_DISPATCHER_ID=-1003741637507
FALLBACK_GROUP_ID=-1003741637507
FALLBACK_GROUP_NAME=Tatiana's Team
FALLBACK_CLAIM_TIMEOUT_MS=60000

# Supabase (optional - uses file storage when not set)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (required for checkout)
STRIPE_SECRET_KEY=sk_live_xxxxx
# Primary app URL for redirects - use one of your domains (comma-separated = first is used)
# Sites: tristatetag.com, tristatetags.com, speedytags.vercel.app
# Comma-separated = both domains for correct redirects (tristatetag.com, tristatetags.com)
APP_URL=https://tristatetag.com,https://tristatetags.com

# Resend (for success emails when delivery = email)
# Get key at https://resend.com - free tier: 100 emails/day
RESEND_API_KEY=re_xxxxx
# Use your domain after verification, e.g. TriState Tags <orders@tristatetag.com>
FROM_EMAIL=TriState Tags <onboarding@resend.dev>
