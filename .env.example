# Admin dashboard password (required for /admin access)
ADMIN_PASSWORD=your-secure-password

# JWT secret for admin session (change in production)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_IDS=-1001234567890,123456789

# Supabase (optional - uses file storage when not set)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (required for checkout)
STRIPE_SECRET_KEY=sk_live_xxxxx
# Primary app URL for redirects - use one of your domains (comma-separated = first is used)
# Sites: tristatetag.com, tristatetags.com, speedytags.vercel.app
APP_URL=https://tristatetag.com

# Resend (for success emails when delivery = email)
# Get key at https://resend.com - free tier: 100 emails/day
RESEND_API_KEY=re_xxxxx
# Use your domain after verification, e.g. TriState Tags <orders@tristatetag.com>
FROM_EMAIL=TriState Tags <onboarding@resend.dev>
